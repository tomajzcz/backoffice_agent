# Database (Neon)
# Get from: https://neon.tech → your project → Connection Details
# Use "Pooled connection" for DATABASE_URL
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# Use "Direct connection" for DIRECT_URL
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# AI (Anthropic)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                Int               @id @default(autoincrement())
  name              String
  email             String            @unique
  phone             String?
  acquisitionSource AcquisitionSource
  segment           ClientSegment
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deals             Deal[]
  properties        Property[]        @relation("PropertyOwner")
  showings          Showing[]
  investor          Investor?
  callLogs          CallLog[]

  @@index([createdAt])
  @@index([acquisitionSource])
  @@map("clients")
}

model Lead {
  id               Int               @id @default(autoincrement())
  name             String
  email            String
  phone            String?
  source           AcquisitionSource
  status           LeadStatus        @default(NEW)
  propertyInterest String?
  createdAt        DateTime          @default(now())
  convertedAt      DateTime?

  @@index([createdAt])
  @@index([source])
  @@index([status])
  @@index([convertedAt])
  @@map("leads")
}

model Property {
  id                 Int                @id @default(autoincrement())
  address            String
  district           String
  type               PropertyType
  price              Decimal            @db.Decimal(12, 2)
  status             PropertyStatus     @default(AVAILABLE)
  areaM2             Decimal            @db.Decimal(8, 2)
  disposition        String?
  yearBuilt          Int?
  lastRenovationYear Int?
  renovationNotes    String?
  lifecycleStage     LifecycleStage?
  stageChangedAt     DateTime?
  purchasePrice      Decimal?           @db.Decimal(12, 2)
  renovationCost     Decimal?           @db.Decimal(12, 2)
  expectedSalePrice  Decimal?           @db.Decimal(12, 2)
  ownerId            Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deals              Deal[]
  owner              Client?            @relation("PropertyOwner", fields: [ownerId], references: [id])
  showings           Showing[]
  tasks              AgentTask[]
  documents          Document[]
  investorProperties InvestorProperty[]
  renovations        Renovation[]

  @@index([district])
  @@index([status])
  @@index([createdAt])
  @@index([lastRenovationYear])
  @@index([lifecycleStage])
  @@map("properties")
}

model Deal {
  id         Int        @id @default(autoincrement())
  propertyId Int
  clientId   Int
  status     DealStatus @default(IN_PROGRESS)
  value      Decimal    @db.Decimal(12, 2)
  closedAt   DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  client     Client     @relation(fields: [clientId], references: [id])
  property   Property   @relation(fields: [propertyId], references: [id])
  tasks      AgentTask[]

  @@index([status])
  @@index([closedAt])
  @@index([createdAt])
  @@map("deals")
}

model Showing {
  id          Int           @id @default(autoincrement())
  propertyId  Int
  clientId    Int
  scheduledAt DateTime
  status      ShowingStatus @default(SCHEDULED)
  notes                 String?
  googleCalendarEventId String?       @map("google_calendar_event_id")
  createdAt             DateTime      @default(now())
  client                Client        @relation(fields: [clientId], references: [id])
  property              Property      @relation(fields: [propertyId], references: [id])
  callLogs              CallLog[]

  @@index([scheduledAt])
  @@index([status])
  @@map("showings")
}

model WeeklyReport {
  id               Int      @id @default(autoincrement())
  weekStart        DateTime @unique @db.Date
  newLeads         Int
  newClients       Int
  propertiesListed Int
  dealsClosed      Int
  revenue          Decimal  @db.Decimal(14, 2)
  createdAt        DateTime @default(now())

  @@index([weekStart])
  @@map("weekly_reports")
}

model AgentTask {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  status        TaskStatus   @default(OPEN)
  priority      TaskPriority @default(MEDIUM)
  dueDate       DateTime?
  assignee      String?
  propertyId    Int?
  dealId        Int?
  renovationId  Int?
  sourceQuery   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  property      Property?    @relation(fields: [propertyId], references: [id])
  deal          Deal?        @relation(fields: [dealId], references: [id])
  renovation    Renovation?  @relation(fields: [renovationId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([propertyId])
  @@index([dealId])
  @@index([renovationId])
  @@index([createdAt])
  @@map("agent_tasks")
}

model ScheduledJob {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  cronExpr    String
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  status      JobStatus          @default(ACTIVE)
  configJson  Json
  notifyEmail String?            @map("notify_email")
  createdAt   DateTime           @default(now())
  results     MonitoringResult[]

  @@map("scheduled_jobs")
}

model MonitoringResult {
  id          Int          @id @default(autoincrement())
  jobId       Int
  source      String
  title       String
  url         String
  price       Decimal?     @db.Decimal(12, 2)
  district    String?
  disposition String?
  areaM2      Decimal?     @db.Decimal(8, 2)
  pricePerM2  Decimal?     @db.Decimal(10, 2)
  score       Int?         @default(0)
  scoreReason String?
  foundAt     DateTime     @default(now())
  isNew       Boolean      @default(true)
  job         ScheduledJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([foundAt])
  @@index([isNew])
  @@index([score])
  @@map("monitoring_results")
}

model AgentRun {
  id              Int      @id @default(autoincrement())
  sessionId       String
  userQuery       String
  toolsCalledJson Json
  outputSummary   String?
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@map("agent_runs")
}

model Investor {
  id         Int                @id @default(autoincrement())
  name       String
  email      String             @unique
  phone      String?
  company    String?
  notes      String?
  clientId   Int?               @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  client     Client?            @relation(fields: [clientId], references: [id])
  properties InvestorProperty[]

  @@index([createdAt])
  @@map("investors")
}

model InvestorProperty {
  id             Int      @id @default(autoincrement())
  investorId     Int
  propertyId     Int
  investedAmount Decimal? @db.Decimal(12, 2)
  notes          String?
  investor       Investor @relation(fields: [investorId], references: [id])
  property       Property @relation(fields: [propertyId], references: [id])

  @@unique([investorId, propertyId])
  @@index([investorId])
  @@index([propertyId])
  @@map("investor_properties")
}

model Document {
  id         Int          @id @default(autoincrement())
  propertyId Int
  type       DocumentType
  name       String
  url        String?
  uploadedAt DateTime     @default(now())
  notes      String?
  property   Property     @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([type])
  @@map("documents")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum PropertyType {
  BYT
  DUM
  POZEMEK
  KOMERCNI
}

enum PropertyStatus {
  AVAILABLE
  IN_NEGOTIATION
  SOLD
  RENTED
  WITHDRAWN
}

enum DealStatus {
  IN_PROGRESS
  CLOSED_WON
  CLOSED_LOST
}

enum ClientSegment {
  INVESTOR
  PRVNI_KUPUJICI
  UPGRADER
  DOWNGRADER
  PRENAJIMATEL
}

enum AcquisitionSource {
  SREALITY
  BEZREALITKY
  DOPORUCENI
  WEB
  INZERCE
  LINKEDIN
}

enum ShowingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum LifecycleStage {
  ACQUISITION
  IN_RENOVATION
  READY_FOR_SALE
  LISTED
  SOLD
}

enum DocumentType {
  KUPNI_SMLOUVA
  NAVRH_NA_VKLAD
  ZNALECKY_POSUDEK
  ENERGETICKY_STITEK
  LIST_VLASTNICTVI
  FOTODOKUMENTACE
  OSTATNI
}

enum RenovationPhase {
  PLANNING
  DEMOLITION
  ROUGH_WORK
  INSTALLATIONS
  SURFACES
  FINISHING
  READY_FOR_HANDOVER
  COMPLETED
  ON_HOLD
}

enum RenovationStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum CallStatus {
  PENDING
  INITIATED
  FAILED
  NO_PHONE
  SKIPPED
}

enum ExecutiveReportStatus {
  RUNNING
  SUCCESS
  FAILED
}

model CallLog {
  id               Int        @id @default(autoincrement())
  showingId        Int
  clientId         Int
  phoneNormalized  String?
  status           CallStatus @default(PENDING)
  elevenLabsCallId String?    @map("elevenlabs_call_id")
  errorMessage     String?
  callDate         DateTime   @db.Date
  createdAt        DateTime   @default(now())
  showing          Showing    @relation(fields: [showingId], references: [id])
  client           Client     @relation(fields: [clientId], references: [id])

  @@unique([showingId, callDate])
  @@index([callDate])
  @@index([showingId])
  @@index([clientId])
  @@map("call_logs")
}

model AutomationConfig {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  isActive       Boolean  @default(true) @map("is_active")
  recipientEmail String   @map("recipient_email")
  cronExpr       String   @map("cron_expr")
  configJson     Json?    @map("config_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("automation_configs")
}

model ExecutiveReportRun {
  id             Int                   @id @default(autoincrement())
  status         ExecutiveReportStatus @default(RUNNING)
  trigger        String                @default("cron")
  recipientEmail String                @map("recipient_email")
  slideCount     Int?                  @map("slide_count")
  pptxToken      String?               @map("pptx_token")
  errorMessage   String?               @map("error_message")
  startedAt      DateTime              @default(now()) @map("started_at")
  finishedAt     DateTime?             @map("finished_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  @@index([startedAt])
  @@index([status])
  @@map("executive_report_runs")
}

model Renovation {
  id             Int              @id @default(autoincrement())
  propertyId     Int
  phase          RenovationPhase  @default(PLANNING)
  status         RenovationStatus @default(ACTIVE)
  startedAt      DateTime         @default(now())
  plannedEndAt   DateTime?
  actualEndAt    DateTime?
  nextStep       String?
  blockers       String?
  ownerName      String?
  contractorName String?
  budgetPlanned  Decimal?         @db.Decimal(12, 2)
  budgetActual   Decimal?         @db.Decimal(12, 2)
  isDelayed      Boolean          @default(false)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  property       Property         @relation(fields: [propertyId], references: [id])
  tasks          AgentTask[]

  @@index([propertyId])
  @@index([status])
  @@index([phase])
  @@index([isDelayed])
  @@map("renovations")
}

model FileToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  prefix    String   @default("")
  data      String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("file_tokens")
}
